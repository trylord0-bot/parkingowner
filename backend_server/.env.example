# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://parkingowner:parkingowner_pw@localhost:3303/parking_owner_db"

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change_this_to_a_long_random_secret_at_least_32_chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── MinIO (S3-compatible file storage) ───────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="parking-owner"

# ── Email (SMTP via Brevo) ───────────────────────────────────────────────────
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your-brevo-login-email@example.com"
SMTP_PASS="your-brevo-smtp-key"
SMTP_FROM="ParkingOwner <noreply@lunlu.co.kr>"

# ── App URL (used in email links) ────────────────────────────────────────────
APP_URL="https://your-domain.com"

# ── Firebase (FCM push notifications) ───────────────────────────────────────
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ── App Admin ────────────────────────────────────────────────────────────────
APP_ADMIN_EMAIL="admin@parkingowner.com"

# ── Daily Report Cron (KST = UTC+9) ──────────────────────────────────────────
# Runs at 09:00 KST = 00:00 UTC
DAILY_REPORT_CRON="0 0 * * *"
